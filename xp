#!/usr/bin/env bash
# Auto-install cron job to run script at 2 AM daily

SCRIPT_PATH="${SCRIPT_PATH:-/usr/local/bin/ziflazz-xp}"

if ! crontab -l 2>/dev/null | grep -q "$SCRIPT_PATH"; then
  (crontab -l 2>/dev/null; echo "0 2 * * * $SCRIPT_PATH") | crontab -
  echo "[OK] Cron job added: Runs at 02:00 every day"
else
  echo "[INFO] Cron job already exists"
fi
